# Runtime connection used by the application.
# For Supabase, prefer the transaction pooler URL here.
DATABASE_URL="postgresql://postgres.project-ref:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"

# Direct connection used by Prisma CLI commands such as migrations.
DIRECT_URL="postgresql://postgres:password@db.project-ref.supabase.co:5432/postgres?sslmode=require"

# Supabase Auth public browser/server values.
NEXT_PUBLIC_SUPABASE_URL="https://project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
